{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: ["github>christfriedbalizou/renovate"],
  dependencyDashboardTitle: "Renovate Dashboard 🤖",
  suppressNotifications: [
    "prEditedNotification",
    "prIgnoreNotification",
  ],
  ignorePaths: [
    "**/*.sops.*",
    "**/resources/**",
    "**/configs/**",
    "**/config/**",
  ],
  flux: {
    managerFilePatterns: ["/(^|/)kubernetes/.+\\.ya?ml(?:\\.j2)?$/"],
  },
  helmfile: {
    managerFilePatterns: [
      "/(^|/)helmfile\\.ya?ml(?:\\.gotmpl)?(?:\\.j2)?$/",
      "/(^|/)helmfile\\.d/.+\\.ya?ml(?:\\.gotmpl)?(?:\\.j2)?$/",
    ],
  },
  kubernetes: {
    managerFilePatterns: ["/(^|/)kubernetes/.+\\.ya?ml(?:\\.j2)?$/"],
  },
  kustomize: {
    managerFilePatterns: ["/^kustomization\\.ya?ml(?:\\.j2)?$/"],
  },
  customManagers: [
    {
      customType: "regex",
      description: "Update vscode venv dotfiles tag",
      managerFilePatterns: [
        "/(^|/)kubernetes/apps/default/vscode/app/helmrelease\\.ya?ml$/",
      ],
      matchStrings: [
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)\\n\\s+VENV_VERSION:\\s*\"?(?<currentValue>v?[^\"\\s]+)\"?",
      ],
      versioningTemplate: "semver",
    },
  ],
}
